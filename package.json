{
  "name": "askgram",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "expo:dev": "expo start",
    "server:dev": "tsx watch server/index.ts",
    "dev": "concurrently \"npm run server:dev\" \"npm run expo:dev\"",
    "db:push": "drizzle-kit push",
    "build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --bundle --platform=node --outfile=dist/server.js",
    "server:prod": "node dist/server.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@tanstack/react-query": "^5.0.0",
    "drizzle-orm": "^0.30.0",
    "expo": "~54.0.0",
    "expo-router": "~6.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-blur": "~14.0.0",
    "express": "^5.0.0",
    "react": "18.3.1",
    "react-native": "0.81.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-keyboard-controller": "^1.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "drizzle-kit": "^0.22.0",
    "esbuild": "^0.20.0",
    "typescript": "~5.3.0",
    "tsx": "^4.7.0"
  }
}
